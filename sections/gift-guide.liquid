{%- liquid
  assign section_id = 'GiftGuide-' | append: section.id
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="{{ section_id }}"
  class="gift-guide"
  style="
    --gift-guide-min-height: {{ section.settings.min_height }}svh;
    --gift-guide-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --gift-guide-top-bar-bg: {{ section.settings.top_bar_bg_color }};
    --gift-guide-nav-btn-bg: {{ section.settings.nav_button_color }};
    --gift-guide-heading-size: {{ section.settings.heading_size }}px;
    --gift-guide-mobile-heading-size: {{ section.settings.mobile_heading_size }}px;
    --gift-guide-mobile-subheading-size: {{ section.settings.mobile_subheading_size }}px;
    --gift-guide-mobile-btn-font-size: {{ section.settings.mobile_btn_font_size }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {%- comment -%} ── TOP BAR (desktop only) ── {%- endcomment -%}
  {%- if section.settings.show_top_bar -%}
    <div class="gift-guide__top-bar">
      <div class="gift-guide__top-bar-inner">

