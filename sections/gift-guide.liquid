        </span>

        {%- if section.settings.tagline != blank -%}
          <span class="gift-guide__tagline">
            {{- section.settings.tagline | escape -}}
          </span>
        {%- endif -%}

        {%- if section.settings.nav_button_label != blank -%}
          <a
            class="gift-guide__nav-btn"
            {% if section.settings.nav_button_url != blank %}
              href="{{ section.settings.nav_button_url }}"
            {% else %}
              href="#"
            {% endif %}
          >
            {{- section.settings.nav_button_label | escape -}}
            <span class="gift-guide__arrow" aria-hidden="true">
              <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
