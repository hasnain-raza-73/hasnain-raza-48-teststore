    <span class="gift-guide__mobile-top-spacer" aria-hidden="true"></span>
  </div>

  {%- comment -%} ── HERO ── {%- endcomment -%}
  <div class="gift-guide__hero">

    {%- comment -%}
      Mobile text block — shown above the image on mobile, hidden on desktop.
      Desktop text is inside the image overlay (.gift-guide__overlay-content).
    {%- endcomment -%}
    <div class="gift-guide__mobile-text">
      {%- if section.settings.heading != blank -%}
        <h2 class="gift-guide__heading">
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}
      {%- if section.settings.mobile_subheading != blank -%}
        <div class="gift-guide__subheading rte">
          {{- section.settings.mobile_subheading -}}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Image block — fills hero on desktop, natural height on mobile {%- endcomment -%}
    <div class="gift-guide__image-block">

      {%- comment -%} Background image {%- endcomment -%}
      {%- if section.settings.background_image != blank -%}
        {%- if section.settings.mobile_image != blank -%}
          <picture>
            <source
              media="(max-width: 749px)"
              srcset="
                {{ section.settings.mobile_image | image_url: width: 416 }} 416w,
                {{ section.settings.mobile_image | image_url: width: 600 }} 600w,
                {{ section.settings.mobile_image | image_url: width: 800 }} 800w,
                {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w
              "
              sizes="100vw"
              width="{{ section.settings.mobile_image.width }}"
              height="{{ section.settings.mobile_image.height }}"
            >
            {{
              section.settings.background_image
              | image_url: width: 3840
              | image_tag:
                widths: '1200, 1600, 1920, 2560, 3840',
                sizes: '100vw',
                alt: section.settings.background_image.alt,
                class: 'gift-guide__bg-img',
                fetchpriority: fetch_priority
            }}
          </picture>
        {%- else -%}
          {{
            section.settings.background_image
            | image_url: width: 3840
            | image_tag:
              widths: '1200, 1600, 1920, 2560, 3840',
              sizes: '100vw',
              alt: section.settings.background_image.alt,
              class: 'gift-guide__bg-img',
              fetchpriority: fetch_priority
          }}
        {%- endif -%}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'gift-guide__bg-img gift-guide__bg-img--placeholder' }}
      {%- endif -%}

      {%- comment -%} Optional overlay {%- endcomment -%}
      {%- if section.settings.overlay_opacity > 0 -%}
        <div class="gift-guide__overlay" aria-hidden="true"></div>
      {%- endif -%}

      {%- comment -%} Desktop content — bottom left overlay {%- endcomment -%}
      <div class="gift-guide__overlay-content">
        {%- if section.settings.heading != blank -%}
          <h2 class="gift-guide__heading">
            {{- section.settings.heading | escape -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="gift-guide__subheading rte">
            {{- section.settings.subheading -}}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            class="gift-guide__cta-btn"
            {% if section.settings.button_url != blank %}
              href="{{ section.settings.button_url }}"
            {% else %}
              href="#"
            {% endif %}
          >
            <span>{{- section.settings.button_label | upcase | escape -}}</span>
            <span class="gift-guide__arrow" aria-hidden="true">
              <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Mobile CTA button — centered on image, shown on mobile only {%- endcomment -%}
      {%- if section.settings.button_label != blank -%}
        <a
          class="gift-guide__cta-btn gift-guide__cta-btn--mobile"
          {% if section.settings.button_url != blank %}
            href="{{ section.settings.button_url }}"
          {% else %}
            href="#"
          {% endif %}
        >
          <span>{{- section.settings.button_label | upcase | escape -}}</span>
          <span class="gift-guide__arrow" aria-hidden="true">
            <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </span>
        </a>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} ── BOTTOM BAR ── {%- endcomment -%}
  {%- if section.settings.show_bottom_bar -%}
    {%- if section.settings.bottom_text != blank -%}
      <div class="gift-guide__bottom-bar gift-guide__bottom-bar--desktop">
        <span class="gift-guide__bottom-text">
          {{- section.settings.bottom_text | upcase | escape -}}
        </span>
      </div>
    {%- endif -%}
    {%- if section.settings.mobile_bottom_text != blank -%}
      <div class="gift-guide__bottom-bar gift-guide__bottom-bar--mobile">
        <span class="gift-guide__bottom-text">
          {{- section.settings.mobile_bottom_text | upcase | escape -}}
        </span>
      </div>
    {%- else -%}
      {%- if section.settings.bottom_text != blank -%}
        {%- comment -%} fallback: reuse desktop text on mobile if no mobile text set {%- endcomment -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

</div>

{% stylesheet %}
  /* ─────────────────────────────────────────
     GIFT GUIDE SECTION
  ───────────────────────────────────────── */
  .gift-guide {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    font-family: "Jost", var(--font-body--family, sans-serif);
  }

  /* ── TOP BAR ── */
  .gift-guide__top-bar {
    background: var(--gift-guide-top-bar-bg, #fff);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    width: 100%;
  }

  .gift-guide__top-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 65px;
    gap: 16px;
    background: #f5f5f5;
}

  .gift-guide__brand-name {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    color: #111;
  }

  .gift-guide__brand-name svg {
    display: block;
    width: 120px;
    height: auto;
  }

  .gift-guide__tagline {
    text-align: center;
    flex: 1;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0px;
    color: #000;
    font-family: Jost;
    line-height: 13.42px;
}

  .gift-guide__nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: #FFF544;
    color: #111;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    padding: 11px 20px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity .2s;
    line-height: 20.48px;
  }

  .gift-guide__nav-btn:hover {
    opacity: 0.85;
  }

  /* ── HERO ── */
  .gift-guide__hero {
    position: relative;
    width: 100%;
  }

  /* Mobile text: hidden on desktop */
  .gift-guide__mobile-text {
    display: none;
  }

  /* Image block — full hero on desktop */
  .gift-guide__image-block {
    position: relative;
    min-height: var(--gift-guide-min-height, 90svh);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .gift-guide__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .gift-guide__bg-img--placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Picture element inside image-block */
  .gift-guide__image-block picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .gift-guide__image-block picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .gift-guide__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--gift-guide-overlay-opacity, 0));
    pointer-events: none;
    z-index: 1;
  }

  /* Desktop overlay content — bottom left */
  .gift-guide__overlay-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 30px;
    padding: 60px 65px;
    max-width: 600px;
    background: white;
  }

  .gift-guide__heading {
    font-size: 70px;
    font-weight: 500;
    line-height: 100%;
    letter-spacing: -.02em;
    color: #111;
    margin: 0;
    font-family: 'Jost';
}

.gift-guide__subheading p {
    font-family: 'Jost';
    font-size: 20px;
    line-height: 140%;
    color: #111;
    margin: 0;
}

  .gift-guide__cta-btn {
    display: inline-flex;
    align-items: center;
    background: #111;
    color: #fff;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 28px;
    margin-top: 8px;
    transition: opacity .2s;
    cursor: pointer;
    font-family: 'Jost';
    max-width: 220px;
    text-align: center;
    justify-content: center;
    margin: 0;
}

  .gift-guide__cta-btn:hover {
    opacity: 0.82;
  }

  /* Mobile CTA button — hidden on desktop */
  .gift-guide__cta-btn--mobile {
    display: none;
  }

  /* Mobile top bar — hidden on desktop */
  .gift-guide__mobile-top-bar {
    display: none;
  }

  .gift-guide__arrow {
    display: inline-flex;
    align-items: center;
    margin-left: 12px;
    flex-shrink: 0;
  }

  .gift-guide__arrow svg {
    display: block;
  }

  /* ── BOTTOM BAR ── */
  .gift-guide__bottom-bar--mobile {
    display: none;
  }

  .gift-guide__bottom-bar {
    background: #F5F5F5;
    border-top: 1px solid rgba(0, 0, 0, .08);
    padding: 5px 28px;
    text-align: center;
}

  .gift-guide__bottom-text {
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0px;
    color: #000000;
    font-family: 'Jost';
    line-height: 13.42px;
}

  /* ── DESKTOP ── */
  @media screen and (min-width: 750px) {
    .gift-guide__top-bar {
      display: block;
    }

    /* Mobile-only elements hidden on desktop */
    .gift-guide__mobile-text {
      display: none;
    }

    .gift-guide__cta-btn--mobile {
      display: none;
    }

    /* Desktop overlay content visible */
    .gift-guide__overlay-content {
      display: flex;
    }
  }

  /* ── MOBILE ── */
  @media screen and (max-width: 749px) {
    /* Hide desktop top bar on mobile */
    .gift-guide__top-bar {
      display: none;
    }

    /* Mobile top bar */
    .gift-guide__mobile-top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 20px;
      background: #F5F5F5;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      position: relative;
    }

    .gift-guide__hamburger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      padding: 4px;
      cursor: pointer;
      flex-shrink: 0;
    }

    .gift-guide__mobile-logo {
      display: inline-flex;
      align-items: center;
      color: #111;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .gift-guide__mobile-logo svg {
      width: 110px;
      height: auto;
      display: block;
    }

    .gift-guide__mobile-top-spacer {
      width: 28px;
      flex-shrink: 0;
    }

    /* Mobile text block above image */
    .gift-guide__mobile-text {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 40px 24px 28px;
      background: #fff;
      gap: 16px;
    }

    .gift-guide__mobile-text .gift-guide__heading {
      font-size: var(--gift-guide-mobile-heading-size, 30px);
      font-weight: 500;
      letter-spacing: 0;
      line-height: 100%;
    }

    .gift-guide__mobile-text .gift-guide__subheading p {
      font-size: var(--gift-guide-mobile-subheading-size, 16px);
      line-height: 1.6;
      color: #333;
    }

    /* Image block — natural height on mobile */
    .gift-guide__image-block {
      min-height: 65vw;
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }

    /* Hide desktop overlay content on mobile */
    .gift-guide__overlay-content {
      display: none;
    }

    /* Mobile CTA button — centered on image */
    .gift-guide__cta-btn--mobile {
      display: inline-flex;
      position: relative;
      z-index: 2;
      margin: 0 auto 40px;
      padding: 16px 40px;
      justify-content: center;
      font-size: var(--gift-guide-mobile-btn-font-size, 16px);
    }

    /* Bottom bar — swap desktop/mobile versions */
    .gift-guide__bottom-bar--desktop {
      display: none;
    }

    .gift-guide__bottom-bar--mobile {
      display: block;
    }

    .gift-guide__bottom-bar {
      padding: 14px 16px;
    }

    .gift-guide__bottom-text {
      font-size: 14px;
    }
  }

  @media screen and (max-width: 480px) {
    .gift-guide__mobile-text {
      padding: 32px 20px 20px;
    }

    .gift-guide__image-block {
      min-height: 65vw;
    }

    .gift-guide__cta-btn--mobile {
      min-width: 75%;
      margin-bottom: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Guide",
  "tag": "section",
  "class": "gift-guide-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Top Bar"
    },
    {
      "type": "checkbox",
      "id": "show_top_bar",
      "label": "Show top bar",
      "default": true,
      "info": "Top bar is hidden on mobile automatically."
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (accessibility label)",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Center tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "nav_button_label",
      "label": "Button label",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "nav_button_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "top_bar_bg_color",
      "label": "Top bar background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "nav_button_color",
      "label": "Button color",
      "default": "#F5E642"
    },
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Background image (mobile)",
      "info": "Optional. Falls back to desktop image if left empty."
    },
    {
      "type": "range",
      "id": "min_height",
